# ============================================================
# Second Avenue — Variáveis de Ambiente
# Copia para .env.local e preenche os valores
# ============================================================

# ── NextAuth ──────────────────────────────────────────────
# Gera um segredo forte:  openssl rand -hex 32
NEXTAUTH_SECRET=substitui-por-um-segredo-aleatorio-de-64-caracteres
NEXTAUTH_URL=http://localhost:3000

# ── Base de Dados (MariaDB) ───────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=secondavenue

# ── Google OAuth ──────────────────────────────────────────
# Cria as credenciais em https://console.cloud.google.com/apis/credentials
# Redirect URI:  http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
